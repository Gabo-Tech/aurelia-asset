{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:app:default",
    "core:window:default",
    "core:event:default",
    "core:path:default",
    "dialog:default",
    "allow-save-export-file",
    "allow-read-import-file",
    "allow-download-model"
  ]
}
