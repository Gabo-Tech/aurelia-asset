{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Portfolio Tracker",
  "version": "0.1.0",
  "identifier": "rocks.gabo.portfoliotracker",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../public",
    "devUrl": "https://financetracker.putopulse.org"
  },
  "app": {
    "windows": [
      {
        "title": "Portfolio Tracker",
        "url": "https://financetracker.putopulse.org",
        "width": 1280,
        "height": 800,
        "minWidth": 360,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "deb", "rpm", "appimage", "msi", "nsis"],
    "category": "Finance",
    "shortDescription": "Private, local portfolio tracker.",
    "longDescription": "Track stocks, ETFs, crypto and metals. Private by design — your data stays on your device.",
    "publisher": "GABO",
    "copyright": "© GABO",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": { "depends": [] },
      "appimage": { "bundleMediaFramework": false }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "wix": { "language": "en-US" },
      "nsis": { "installMode": "perMachine" }
    },
    "android": {
      "minSdkVersion": 24
    },
    "iOS": {
      "minimumSystemVersion": "13.0"
    }
  },
  "plugins": {}
}
