# Copy to .env (local dev) or set as runtime secrets in production.
# All variables are read server-side only; never expose them to the client.

# Finnhub API key used by /api/finance-proxy as the primary price source.
# Get one for free at https://finnhub.io
FINNHUB_API_KEY=

# Admin password for the /admin sponsors panel.
# Use a long random string.
ADMIN_PASSWORD=

# GitHub repo where data/sponsors.json is persisted from the admin panel.
# Format: "owner/repo". Branch defaults to "main".
GITHUB_REPO=
GITHUB_BRANCH=main

# GitHub fine-grained token with "Contents: read & write" on GITHUB_REPO.
GITHUB_TOKEN=
